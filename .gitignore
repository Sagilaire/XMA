*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
env/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
*.log

# ---- Node / React / Vite (frontend) ----
node_modules/
dist/
.vite/
*.local
.cache/

